# ============================================================================
# Environment Configuration Template
# ============================================================================
# Copy this file to .env and update with your actual values

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# FastAPI
# ============================================================================
API_TITLE=Knowledge Base Search API
API_VERSION=1.0.0
API_WORKERS=4
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://kb_user:your-secure-password@postgresql:5432/kb_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ============================================================================
# Meilisearch
# ============================================================================
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=your-32-char-secret-key-minimum
MEILISEARCH_INDEX=kb_documents
MEILISEARCH_TIMEOUT=30

# ============================================================================
# Qdrant
# ============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=kb_embeddings
QDRANT_TIMEOUT=30
EMBEDDING_DIMENSION=1536

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_EMBEDDING_TTL=2592000

# ============================================================================
# LiteLLM / OpenAI
# ============================================================================
LITELLM_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT=60
BATCH_EMBEDDING_SIZE=25

# ============================================================================
# Search Behavior
# ============================================================================
DEFAULT_SEARCH_LIMIT=10
MAX_SEARCH_LIMIT=100
DEFAULT_SEMANTIC_WEIGHT=0.5
SEMANTIC_THRESHOLD=0.6

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_PER_HOUR=60000

# ============================================================================
# Circuit Breaker
# ============================================================================
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ============================================================================
# Indexing
# ============================================================================
ASYNC_INDEXING_ENABLED=true
INDEXING_MAX_RETRIES=3
INDEXING_RETRY_DELAY=5
